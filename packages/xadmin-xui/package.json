{
  "name": "xadmin-xui",
  "version": "3.0.3",
  "description": "Xadmin XUI",
  "main": "dist/index.cjs.js",
  "module": "dist/index.es.js",
  "unpkg": "dist/index.umd.js",
  "author": "sshwsfc@gmail.com",
  "license": "MIT",
  "dependencies": {},
  "peerDependencies": {
    "react": ">=17",
    "react/jsx-runtime": ">=17",
    "lodash": "4",
    "moment": "2",
    "react-router": "6",
    "react-router-dom": "6",
    "lucide-react": "^0.474.0",
    "xadmin": "2 || 3",
    "xadmin-auth": "3",
    "xadmin-i18n": "3",
    "xadmin-form": "3",
    "xadmin-model": "3",
    "xadmin-ui": "3",
    "xui": "1"
  },
  "scripts": {
    "vite": "vite build --config ../../vite.config.js",
    "build:lib": "babel src --extensions \".js,.jsx,.ts,.tsx\" --root-mode upward --out-dir lib",
    "build:es": "cross-env BABEL_ENV=es babel src --extensions \".js,.jsx,.ts,.tsx\" --root-mode upward --out-dir es",
    "build:umd": "USE_TS=true rollup -c ../../rollup.config.js",
    "clean": "rm -rf lib es dist",
    "build": "npm run clean && npm run build:lib && npm run build:es"
  },
  "files": [
    "lib",
    "es",
    "dist"
  ]
}

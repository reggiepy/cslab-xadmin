{
  "name": "xadmin-model",
  "version": "3.3.5",
  "description": "Xadmin Model",
  "main": "dist/index.cjs.js",
  "module": "dist/index.es.js",
  "unpkg": "dist/index.umd.js",
  "author": "sshwsfc@gmail.com",
  "license": "MIT",
  "peerDependencies": {
    "lodash": "^4.17.4",
    "moment": "2",
    "react": ">=16.8",
    "react-router-dom": "6",
    "jotai": "^2.15.1",
    "jotai/utils": "^2.15.1",
    "xadmin": "2||3",
    "xadmin-form": "3",
    "xadmin-i18n": "3",
    "xadmin-ui": "3"
  },
  "scripts": {
    "vite": "vite build --config ../../vite.config.js",
    "build:lib": "babel src --root-mode upward --out-dir lib",
    "build:es": "cross-env BABEL_ENV=es babel src --root-mode upward --out-dir es",
    "build:umd": "rollup -c ../../rollup.config.js",
    "clean": "rm -rf lib es dist",
    "build": "npm run clean && npm run build:lib && npm run build:es && npm run build:umd"
  },
  "files": [
    "lib",
    "es",
    "dist"
  ]
}
